# Phase 2 — LTA Datamall API key
# Register a free account at https://datamall.lta.gov.sg and request an
# AccountKey. Set this in Vercel → Project → Settings → Environment Variables
# for both Production and Preview. Never commit the real value to git.
LTA_ACCOUNT_KEY=

# Phase 3 — OneMap account credentials (for the routing API)
# Register at https://www.onemap.gov.sg/apidocs/register. The server-side
# /api/onemap-route function exchanges these for a bearer token (cached
# in-memory for ~3 days) before each routing call. Never sent to the browser.
ONEMAP_EMAIL=
ONEMAP_PASSWORD=

# Google Places API key (for destination search typeahead + nearby carparks)
# Google Cloud → Maps Platform → enable "Places API (New)". Used server-side
# by /api/google-places-autocomplete, /api/google-places-details, and
# /api/google-places-nearby. The key never reaches the browser; restrict it to
# those endpoints + your domain.
GOOGLE_PLACES_API_KEY=

# Gap-fill threshold for supplementary Google carparks (client-side, VITE_).
# Show Google nearby carparks only when our own DB returns FEWER than this many
# carparks nearby. Change it here (or in Vercel → Settings → Environment
# Variables) without editing code; a redeploy applies it.
#   5   → default: fill gaps in sparse areas (e.g. Jewel/Changi), DB-only elsewhere
#   999 → effectively always show Google
#   0   → never show Google
VITE_GOOGLE_GAP_THRESHOLD=5

# URA Data Service AccessKey (for real per-band rate schedules on URA carparks)
# Register at https://www.ura.gov.sg/maps/api/. The server-side
# /api/ura-carpark-details and /api/ura-token functions mint a daily Token
# from this AccessKey, and never send either header to the browser. Also used
# by the daily rate ingest (scripts/ingest-ura-rates.ts + the Vercel cron).
URA_ACCESS_KEY=

# Secret guarding the daily URA rate-ingest cron (/api/cron/ura-rates-ingest).
# Vercel auto-injects this as `Authorization: Bearer <CRON_SECRET>` on cron
# invocations; the handler rejects any request without it. Set it in Vercel →
# Project → Settings → Environment Variables. Not needed for local script runs.
CRON_SECRET=

# ── Supabase ────────────────────────────────────────────────────────────
# The app reads the carparks + rate_rows tables directly from the browser
# via PostgREST. VITE_ prefix means Vite inlines these at build time. The
# anon key is safe to ship — Row-Level Security keeps writes service-role
# only. The non-VITE pair is used by scripts/migrate-to-supabase.ts.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Sign-In ──────────────────────────────────────────────────────
# OAuth 2.0 Web client ID from Google Cloud Console.
#   1. https://console.cloud.google.com/apis/credentials
#   2. Create Credentials → OAuth client ID → Web application
#   3. Add Authorized JavaScript origins:
#        http://localhost:5173  (dev)
#        https://wheretopark.sg (prod, when shipping)
#   4. Copy the Client ID into .env.local
# VITE_ prefix means Vite inlines it at build time. Public — safe to ship.
VITE_GOOGLE_CLIENT_ID=
